# Example environment variables for NO-CLONE-traefik
# Copy this file to .env and set the actual values there.

# Traefik dashboard basic auth hash for the admin user.
# Used by the traefik.http.middlewares.dashboard-auth.basicauth.users label.
# Generate a hash with htpasswd (Apache) or a compatible tool:
#   htpasswd -nbB admin <password>
# Then copy the output here, escaping dollar signs for Docker Compose, e.g.
# admin:$$apr1$$... or admin:$$2y$$...
DASHBOARD_BASIC_AUTH_HASH=$thisismyhashedpassword

# Hostname for the Traefik dashboard router used by the dashboard rule.
DASHBOARD_HOST=dashboard.traefik.no-clone-traefik.orb.local

